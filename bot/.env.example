# ════════════════════════════════════════════════════
#  Football Live Stream Bot  —  Environment Config
#  Copy this file to .env and fill in your values
# ════════════════════════════════════════════════════

# ── Telegram API Credentials ──────────────────────────
# Get these from https://my.telegram.org/apps
API_ID=12345678
API_HASH=your_api_hash_here

# ── Bot Token ─────────────────────────────────────────
# Get from @BotFather on Telegram
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# ── User Session ──────────────────────────────────────
# Name for the Pyrogram session file (no extension)
SESSION_NAME=stream_session

# ── API Server ────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# Secret key — must match VITE_BOT_API_SECRET in the React app
API_SECRET=my-super-secret-key-change-this

# ── Stream Quality ────────────────────────────────────
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720
VIDEO_FPS=30
VIDEO_BITRATE=2000
AUDIO_BITRATE=128
